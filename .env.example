# ─── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Web Push Notifications (No Firebase needed!) ──────────────────────────────
# Generated once. Public key goes in frontend. Private key stays server-side.
# To generate a new pair: npx web-push generate-vapid-keys --json
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# ─── Training "Generate with AI" question drafting ─────────────────────────────
# Groq (recommended — free, no billing, no card). Get a key at console.groq.com.
# Text-based: the AI drafts questions from the "source notes" you paste in the UI.
VITE_GROQ_API_KEY=your-groq-api-key
#
# Gemini (optional fallback) — reads uploaded PDFs/images directly.
# Get a key at https://aistudio.google.com/apikey (needs prepaid credits in some
# regions, e.g. India). Used only if the Groq key is absent.
# NOTE: VITE_ vars are bundled into the client, so these keys are visible in the
# browser — treat them as low-privilege and restrict them where possible.
VITE_GEMINI_API_KEY=your-gemini-api-key

# ─── Supabase Vault Secrets (Server-side only — NOT in this file) ──────────────
# Add these in Supabase Dashboard → Settings → Vault:
#
#   VAPID_PRIVATE_KEY  = your-vapid-private-key
#   VAPID_PUBLIC_KEY   = your-vapid-public-key
#   VAPID_SUBJECT      = mailto:your@email.com
#
#   META_WHATSAPP_TOKEN    = (from Meta Developer Console)
#   META_PHONE_NUMBER_ID   = (from Meta Developer Console)
#   APP_BASE_URL           = https://your-horae-domain.com
